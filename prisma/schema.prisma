generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model admins {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @db.VarChar(150)
  email         String    @unique @db.VarChar(255)
  password_hash String
  role          String    @default("admin") @db.VarChar(20)
  is_active     Boolean?  @default(true)
  created_by    String?   @db.Uuid
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  deleted_at    DateTime? @db.Timestamp(6)
  phone_number  String?   @unique @db.VarChar(20)

  permissions         admin_permissions[] @relation("AdminOwnedPermissions")
  granted_permissions admin_permissions[] @relation("AdminGrantedPermissions")
  creator             admins?             @relation("AdminHierarchy", fields: [created_by], references: [id], onUpdate: NoAction)
  created_accounts    admins[]            @relation("AdminHierarchy")
  approved_reviews    reviews[]           @relation("ReviewApprover")
  reviews             reviews[]           @relation("AdminReviews")

  @@index([email], map: "idx_admins_email")
  @@index([role], map: "idx_admins_role")
}

model admin_permissions {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id      String      @db.Uuid
  permission_id Int
  granted_by    String?     @db.Uuid
  granted_at    DateTime?   @default(now()) @db.Timestamp(6)
  admin         admins      @relation("AdminOwnedPermissions", fields: [admin_id], references: [id], onDelete: Cascade)
  granter       admins?     @relation("AdminGrantedPermissions", fields: [granted_by], references: [id])
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: NoAction)

  @@unique([admin_id, permission_id])
}

model permissions {
  id                Int                 @id @default(autoincrement())
  name              String              @unique @db.VarChar(100)
  description       String?
  module            String?             @db.VarChar(50)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  admin_permissions admin_permissions[]

  @@index([id, name], map: "idx_permission_in_store")
}

model customers {
  id             String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name     String                    @db.VarChar(100)
  last_name      String                    @db.VarChar(100)
  email          String                    @unique @db.VarChar(255)
  phone          String?                   @unique @db.VarChar(20)
  password_hash  String?
  is_active      Boolean?                  @default(true)
  created_at     DateTime?                 @default(now()) @db.Timestamp(6)
  deleted_at     DateTime?                 @db.Timestamp(6)
  passwordResets PasswordReset[]
  addresses      addresses[]
  carts          carts[]
  auth_providers customer_auth_providers[]
  orders         orders[]
  reviews        reviews[]
  wishlists      wishlists[]

  @@index([email], map: "idx_customers_email")
}

model customer_auth_providers {
  id          String       @id @default(uuid())
  customer_id String       @db.Uuid
  provider_id String       @db.VarChar(255)
  created_at  DateTime     @default(now())
  provider    AuthProvider
  customer    customers    @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_id])
  @@index([customer_id])
}

model PasswordReset {
  id          String    @id @default(uuid()) @db.Uuid
  customer_id String    @db.Uuid
  token_hash  String    @unique
  expires_at  DateTime
  used        Boolean   @default(false)
  created_at  DateTime  @default(now())
  customer    customers @relation(fields: [customer_id], references: [id])

  @@index([customer_id, token_hash])
}

model categories {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id       String?      @db.Uuid
  name            String       @db.VarChar(150)
  slug            String       @unique @db.VarChar(150)
  description     String?
  is_active       Boolean?     @default(true)
  attribute_rules Json?        @default("[]")
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  updated_at      DateTime?    @updatedAt @db.Timestamp(6)
  parent          categories?  @relation("CategoryHierarchy", fields: [parent_id], references: [id], onUpdate: NoAction)
  sub_categories  categories[] @relation("CategoryHierarchy")
  products        products[]

  @@unique([name], map: "uq_categories_name")
  @@index([parent_id], map: "idx_categories_parent")
  @@index([slug], map: "idx_categories_slug")
  @@index([name], map: "idx_categories_name")
}

model products {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id String             @db.Uuid
  name        String             @db.VarChar(255)
  slug        String             @unique @db.VarChar(255)
  description String?
  base_price  Decimal            @db.Decimal(10, 2)
  is_active   Boolean?           @default(true)
  created_at  DateTime?          @default(now()) @db.Timestamp(6)
  deleted_at  DateTime?          @db.Timestamp(6)
  images      product_images[]
  variants    product_variants[]
  category    categories         @relation(fields: [category_id], references: [id])
  reviews     reviews[]
  wishlists   wishlists[]

  @@index([category_id], map: "idx_products_category")
  @@index([slug], map: "idx_products_slug")
  @@index([is_active], map: "idx_products_active")
  @@index([created_at], map: "idx_products_created_at")
  @@index([deleted_at], map: "idx_products_deleted_at")
  // FILTER + SORT (common in listings)
  @@index([category_id, is_active], map: "idx_products_category_active")
}

model product_images {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String   @db.Uuid
  key        String
  url        String?
  alt_text   String?  @db.VarChar(255)
  is_primary Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  product    products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, key])
  @@index([product_id])
  @@index([product_id, is_primary])
  @@index([product_id, sort_order])
}

model product_variants {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id        String        @db.Uuid
  sku               String        @unique @db.VarChar(100)
  attributes        Json          @default("{}")
  attributes_hash   String        @db.VarChar(64)
  weight            Decimal       @default(0.50) @db.Decimal(10, 2)
  price             Decimal       @db.Decimal(10, 2)
  stock_quantity    Int           @default(0)
  reserved_quantity Int           @default(0)
  reorder_level     Int           @default(5)
  deleted_at        DateTime?     @db.Timestamp(6)
  product           products      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  cart_items        cart_items[]
  order_items       order_items[]

  @@unique([product_id, attributes_hash])
  @@index([product_id])
  @@index([price])
  @@index([stock_quantity])
  @@index([stock_quantity, reserved_quantity])
}

model carts {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String?      @db.Uuid
  session_id  String?      @db.VarChar(255)
  coupon_id   String?      @db.Uuid
  status      cart_status  @default(ACTIVE)
  created_at  DateTime     @default(now()) @db.Timestamp(6)
  updated_at  DateTime     @updatedAt @db.Timestamp(6)
  expires_at  DateTime?    @db.Timestamp(6)
  customer    customers?   @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  coupon      coupons?     @relation(fields: [coupon_id], references: [id], onDelete: SetNull)
  items       cart_items[]

  @@index([customer_id])
  @@index([session_id])
  @@index([coupon_id])
  @@index([status])
  @@index([expires_at], map: "idx_carts_expires_at")
}

model cart_items {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cart_id    String           @db.Uuid
  variant_id String           @db.Uuid
  quantity   Int              @default(1)
  created_at DateTime         @default(now()) @db.Timestamp(6)
  updated_at DateTime         @updatedAt @db.Timestamp(6)
  cart       carts            @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  variant    product_variants @relation(fields: [variant_id], references: [id], onDelete: Restrict)

  @@unique([cart_id, variant_id])
  @@index([cart_id])
  @@index([variant_id])
}

model orders {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_number    String        @unique @db.VarChar(50)
  customer_id     String?       @db.Uuid
  address_id      String?       @db.Uuid
  guest_name      String?       @db.VarChar(150)
  guest_email     String?       @db.VarChar(255)
  guest_phone     String?       @db.VarChar(20)
  guest_address   Json?
  coupon_id       String?       @db.Uuid
  status          OrderStatus   @default(PENDING)
  payment_method  PaymentMethod
  payment_status  PaymentStatus @default(UNPAID)
  subtotal        Decimal       @db.Decimal(10, 2)
  discount_amount Decimal       @default(0) @db.Decimal(10, 2)
  shipping_cost   Decimal       @default(0) @db.Decimal(10, 2)
  total_amount    Decimal       @db.Decimal(10, 2)
  placed_at       DateTime      @default(now()) @db.Timestamp(6)

  customer customers? @relation(fields: [customer_id], references: [id])
  address  addresses? @relation(fields: [address_id], references: [id])
  coupon   coupons?   @relation(fields: [coupon_id], references: [id])

  items     order_items[]
  payments  payments[]
  shipments shipments[]
  reviews   reviews[]

  @@index([customer_id], map: "idx_orders_customer")
  @@index([status], map: "idx_orders_status")
  @@index([placed_at], map: "idx_orders_placed_at")
  @@index([payment_status], map: "idx_orders_payment_status")
  @@index([customer_id, placed_at], map: "idx_orders_customer_placed_at")
  @@index([status, placed_at], map: "idx_orders_status_placed_at")
}

model order_items {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String  @db.Uuid
  variant_id      String? @db.Uuid
  product_name    String  @db.VarChar(255)
  sku             String? @db.VarChar(100)
  variant_options Json?
  quantity        Int
  unit_price      Decimal @db.Decimal(10, 2)
  total_price     Decimal @db.Decimal(10, 2)

  order   orders            @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant product_variants? @relation(fields: [variant_id], references: [id])

  @@index([order_id], map: "idx_order_items_order")
  @@index([variant_id], map: "idx_order_items_variant")
}

model addresses {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String    @db.Uuid
  label         String?   @db.VarChar(50)
  street        String
  city          String    @db.VarChar(100)
  province      String    @db.VarChar(100)
  province_code String    @db.VarChar(2)
  country       String    @db.VarChar(100)
  country_code  String    @db.Char(2)
  postal_code   String?   @db.VarChar(20)
  is_default    Boolean   @default(false)
  customer      customers @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  orders        orders[]

  @@unique([customer_id, is_default])
}

model coupons {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String      @unique @db.VarChar(50)
  type            coupon_type
  value           Decimal     @db.Decimal(10, 2)
  min_order_value Decimal?    @db.Decimal(10, 2)
  max_discount    Decimal?    @db.Decimal(10, 2)
  max_uses        Int?
  used_count      Int         @default(0)
  is_active       Boolean     @default(true)
  starts_at       DateTime?   @db.Timestamp(6)
  expires_at      DateTime?   @db.Timestamp(6)
  created_at      DateTime    @default(now()) @db.Timestamp(6)
  updated_at      DateTime    @updatedAt @db.Timestamp(6)

  orders orders[]
  carts  carts[]

  @@index([is_active])
  @@index([code])
  @@index([is_active, starts_at, expires_at])
}

model payments {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id       String        @db.Uuid
  method         PaymentMethod
  status         PaymentStatus @default(UNPAID)
  amount         Decimal       @db.Decimal(10, 2)
  transaction_id String?       @unique @db.VarChar(255)
  paid_at        DateTime?     @db.Timestamp(6)

  order orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id], map: "idx_payments_order")
  @@index([status], map: "idx_payments_status")
}

model reviews {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id       String       @db.Uuid
  product_id        String       @db.Uuid
  order_id          String       @db.Uuid
  rating            Int          @db.SmallInt
  title             String?      @db.VarChar(120)
  comment           String?
  status            ReviewStatus @default(PENDING)
  rejection_reason  String?
  verified_purchase Boolean      @default(true)
  helpful_count     Int          @default(0)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  approved_at       DateTime?
  approved_by       String?      @db.Uuid
  author_id         String?      @db.Uuid

  customer customers @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  product  products  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order    orders    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  approver admins? @relation("ReviewApprover", fields: [approved_by], references: [id], onDelete: SetNull)
  author   admins? @relation("AdminReviews", fields: [author_id], references: [id], onDelete: SetNull)

  @@unique([customer_id, product_id, order_id])
  @@index([product_id, status])
  @@index([product_id, rating])
  @@index([product_id, status, created_at])
  @@index([customer_id])
  @@index([status])
  @@index([approved_by])
  @@index([author_id])
  @@index([created_at])
}

model shipments {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String         @db.Uuid
  carrier         String?        @db.VarChar(100)
  tracking_number String?        @db.VarChar(255)
  transaction_id  String?        @db.VarChar(225)
  label_url       String?        @db.VarChar(500)
  status          ShipmentStatus @default(PROCESSING)
  shipped_at      DateTime?      @db.Timestamp(6)
  delivered_at    DateTime?      @db.Timestamp(6)

  order orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id], map: "idx_shipments_order")
  @@index([status], map: "idx_shipments_status")
  @@index([tracking_number], map: "idx_shipments_tracking")
}

model wishlists {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String   @db.Uuid
  product_id  String   @db.Uuid
  added_at    DateTime @default(now()) @db.Timestamp(6)

  // Relations
  customer customers @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  product  products  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, product_id])
  @@index([customer_id])
  @@index([product_id])
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token_hash String    @unique
  user_id    String    @db.Uuid
  user_type  String    @db.VarChar(10)
  expires_at DateTime  @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

enum AuthProvider {
  google
}

enum coupon_type {
  PERCENTAGE
  FIXED
}

enum cart_status {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  CANCELLED
}

enum ShipmentStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
